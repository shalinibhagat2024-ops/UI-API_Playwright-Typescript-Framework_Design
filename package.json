{
  "name": "ui-api_playwright-typescript_framework",
  "version": "1.0.0",
  "description": "Enterprise UI & API Automation Framework using Playwright + TypeScript",
  "main": "index.js",
  "type": "commonjs",
  "lint-staged": {
    "*.{ts,tsx,js}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,yml,yaml,md}": [
      "prettier --write"
    ]
  },
  "scripts": {
    "auth:admin": "playwright test --project=setup-admin",
    "ui": "playwright test --project=ui",
    "api": "playwright test --project=api",
    "report:clean": "rimraf allure-results allure-report",
    "report:generate": "allure generate allure-results --clean -o allure-report",
    "report:open": "allure open allure-report",
    "report:serve": "allure serve allure-results",
    "test:api:report": "npm run test:api && npm run report:generate && npm run report:open",
    "report:ui": "npm run report:clean && playwright test --project=chromium && npm run report:generate && npm run report:open",
    "report:all": "npm run report:clean && playwright test && npm run report:generate && npm run report:open",
    "lint": "eslint . --ext .ts",
    "lint:fix": "eslint . --fix",
    "type-check": "tsc --noEmit",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "build": "tsc"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/shalinibhagat2024-ops/UI-API_Playwright-Typescript_Demo.git"
  },
  "bugs": {
    "url": "https://github.com/shalinibhagat2024-ops/UI-API_Playwright-Typescript_Demo/issues"
  },
  "homepage": "https://github.com/shalinibhagat2024-ops/UI-API_Playwright-Typescript_Demo#readme",
  "keywords": [
    "playwright",
    "typescript",
    "automation",
    "ui-testing",
    "api-testing",
    "allure"
  ],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@eslint/js": "^9.39.5",
    "@playwright/test": "^1.61.0",
    "@types/ajv": "^0.0.5",
    "@types/node": "^26.0.0",
    "@types/papaparse": "^5.5.2",
    "@types/xlsx": "^0.0.35",
    "@typescript-eslint/eslint-plugin": "^8.64.0",
    "@typescript-eslint/parser": "^8.64.0",
    "allure-commandline": "^2.43.0",
    "allure-js-commons": "^3.10.2",
    "allure-playwright": "^3.10.2",
    "cross-env": "^10.1.0",
    "eslint": "^9.39.5",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-simple-import-sort": "^14.0.0",
    "globals": "^17.7.0",
    "husky": "^9.1.7",
    "json-server": "^1.0.0-beta.15",
    "prettier": "^3.9.5",
    "rimraf": "^6.0.1",
    "ts-morph": "^28.0.0",
    "tsx": "^4.23.1",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.64.0"
  },
  "dependencies": {
    "@faker-js/faker": "^10.5.0",
    "ajv": "^8.20.0",
    "csv-parser": "^3.2.1",
    "dotenv": "^17.4.2",
    "luxon": "^3.7.2",
    "papaparse": "^5.5.4",
    "xlsx": "^0.18.5"
  }
}
