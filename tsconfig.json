{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "moduleResolution": "Node",

    "strict": true,

    "esModuleInterop": true,

    "resolveJsonModule": true,

    "allowSyntheticDefaultImports": true,

    "forceConsistentCasingInFileNames": true,

    "skipLibCheck": true,

    "types": [
      "node",
      "@playwright/test"
    ],

    "baseUrl": ".",

    "paths": {
      "@pages/*": [
        "src/pages/*"
      ],
      "@components/*": [
        "src/components/*"
      ],
      "@fixtures/*": [
        "src/fixtures/*"
      ],
      "@utils/*": [
        "src/utils/*"
      ],
      "@api/*": [
        "src/api/*"
      ],
      "@data/*": [
        "src/data/*"
      ],
      "@config/*": [
        "config/*"
      ]
    }
  },

  "include": [
    "src",
    "tests",
    "playwright.config.ts"
  ],

  "exclude": [
    "node_modules",
    "playwright-report",
    "test-results"
  ]
}