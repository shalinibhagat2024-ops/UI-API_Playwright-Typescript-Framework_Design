{
  "compilerOptions": {
    "target": "ES2022",

    "module": "NodeNext",
    "moduleResolution": "NodeNext",

    "strict": true,

    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,

    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,

    "types": [
      "node",
      "@playwright/test"
    ]
  },

  "include": [
    "src",
    "tests",
    "playwright.config.ts"
  ],

  "exclude": [
    "node_modules",
    "playwright-report",
    "test-results"
  ]
}